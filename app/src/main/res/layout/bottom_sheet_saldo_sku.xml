<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="24dp">

    <!-- Alça -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="#CCCCCC"
        android:backgroundTint="@color/text_muted" />

    <!-- Cabeçalho -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SALDO POR SKU"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

        <!-- Legenda -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENT  |  SAÍ  |  SALDO"
            android:textColor="@color/text_muted"
            android:textSize="9sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Estado vazio -->
    <TextView
        android:id="@+id/txtSaldoVazio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nenhum produto registrado ainda."
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSaldos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp"
        android:nestedScrollingEnabled="true"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

</LinearLayout>
